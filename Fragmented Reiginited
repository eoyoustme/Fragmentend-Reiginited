local function rollChance(percent)
	return math.random(1, 100) <= percent
end

local function spawnEntity(entityData)
	pcall(function()
		loadstring(game:HttpGet(entityData.url))()
	end)
end

local function IsSeekActive()
	local currentRooms = game.Workspace:FindFirstChild("CurrentRooms")
	if not currentRooms then
		return false
	end

	local namesToCheck = {
		"Seek",
		"SeekMoving",
		"SeekMovingNewClone",
		"SeekEntity",
		"SeekDoor"
	}

	for _, name in ipairs(namesToCheck) do
		if game.Workspace:FindFirstChild(name, true) then
			return true
		end
		if currentRooms:FindFirstChild(name, true) then
			return true
		end
	end

	-- Dò thêm theo tên chứa "seek"
	for _, inst in ipairs(game.Workspace:GetDescendants()) do
		local n = string.lower(inst.Name)
		if string.find(n, "seek") then
			return true
		end
	end

	return false
end

math.randomseed(os.clock() * 1e6)

