local function GetRoom()
	local rooms = workspace.CurrentRooms
	return rooms:FindFirstChild(game.ReplicatedStorage.GameData.LatestRoom.Value)
end

-- Chỉ đợi lần đầu
game.ReplicatedStorage.GameData.LatestRoom.Changed:Wait()

for i = 1,5 do
	local camera = workspace.CurrentCamera
	local s = game:GetObjects("rbxassetid://70974040244246")[1]
	s.Parent = workspace

	local entity = s:FindFirstChildWhichIsA("BasePart")
	if not entity then
		s:Destroy()
		break
	end
	
	local startFov = camera.FieldOfView
	local zoomFov = 90
	local zoomDuration = 0.5

	entity.CFrame = GetRoom():WaitForChild("RoomEntrance").CFrame * CFrame.new(0,0,-15)

	-- Tắt Particle
	local attachment = entity:FindFirstChild("Attachment")
	if attachment then
		for _,v in ipairs(attachment:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v.Enabled = false
			end
		end
	end

	wait(0.5)
	
	camera.CameraType = Enum.CameraType.Custom
	camera.FieldOfView = startFov
	
	local CameraShaker = require(game.ReplicatedStorage.CameraShaker)
	local camara = game.Workspace.CurrentCamera
	local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCf)
		camara.CFrame = camara.CFrame * shakeCf
	end)
	camShake:Start()
	camShake:ShakeOnce(10,10,0.5,0.5,2,0.5)


	-- Phát Repent
	local repent = entity:FindFirstChild("Repent")
	if repent then
		repent:Play()
		repent.Ended:Wait()
	end

	-- Bật Particle
	if attachment then
		for _,v in ipairs(attachment:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v.Enabled = true
			end
		end
	end

	-- Phát Playsound
	local playSound = entity:FindFirstChild("Playsound")
	if playSound then
		playSound.Volume = 5
		playSound:Play()
		
		local distro = playSound:FindFirstChildWhichIsA("DistortionSoundEffect")
		if distro then
			distro.Level = 0.99
		end
		
		local Sceam = entity:FindFirstChild("Scream")
		if Sceam then
			Sceam.Volume = 5

			local distro = playSound:FindFirstChildWhichIsA("DistortionSoundEffect")
			if distro then
				distro.Level = 0.99
			end
			end
	end

	local attacking = true

	local roomConnection
	roomConnection = workspace.CurrentRooms.ChildAdded:Connect(function()
		if not attacking then
			return
		end

		attacking = false

		if roomConnection then
			roomConnection:Disconnect()
		end

		if s then
			s:Destroy()
		end
	end)

	task.spawn(function()
		while attacking and entity.Parent do
			task.wait(1)

			local player = game.Players.LocalPlayer
			local char = player.Character

			if char then
				local hum = char:FindFirstChildOfClass("Humanoid")
				local hrp = char:FindFirstChild("HumanoidRootPart")

				if hum and hrp and (hrp.Position - entity.Position).Magnitude <= 50 then
					hum.Health -= 5
					game.ReplicatedStorage.GameStats["Player_" .. player.Name].Total.DeathCause.Value = "Fluster"
				end
			end
		end
	end)

	-- Đợi entity biến mất rồi spawn cái tiếp theo
	repeat
		task.wait()
	until not attacking
end
