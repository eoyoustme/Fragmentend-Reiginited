local colors = {
	Color3.fromRGB(160, 206, 255),
	Color3.fromRGB(0, 123, 255),
	Color3.fromRGB(0, 208, 255),
	Color3.fromRGB(120, 174, 255),
	Color3.fromRGB(255, 255, 255),
	Color3.fromRGB(37, 84, 255),
	Color3.fromRGB(133, 255, 237)
}

local oldActive = true
local transitioning = false

local function playSoundSafe(soundObj, timePos, speed, volume)
	if not soundObj or not soundObj.Parent then
		return
	end

	soundObj:Stop()
	soundObj.TimePosition = timePos or 0
	soundObj.PlaybackSpeed = speed or 1
	soundObj.Volume = volume or 1
	soundObj:Play()
end


math.randomseed(tick())
oldSound:Play()

task.spawn(function()
	while oldActive and screenGui.Parent do
		task.wait(0.08)

		local Rotation = oldImage.Rotation
		local v2

		if math.random(1, 2) == 1 then
			v2 = -Rotation
		else
			v2 = Rotation + math.random(-360, 360)
		end

		local v3 = v2 + math.random(-360, 360)

		if v3 > 180 then
			v3 = 180
		end

		if v3 < -180 then
			v3 = -180
		end

		-- đổi background liên tục trong lúc jumpscare cũ còn chạy
		bg.BackgroundColor3 = colors[math.random(1, #colors)]
		oldImage.ImageColor3 = colors[math.random(1, #colors)]

		TweenService:Create(oldImage, TweenInfo.new(0.08), {
			Size = UDim2.new(0, math.random(650, 950), 1, math.random(650, 950))
		}):Play()

		task.delay(0.03333333333333333, function()
			if oldImage and oldImage.Parent and oldActive then
				TweenService:Create(oldImage, TweenInfo.new(1000), {
					Size = UDim2.new(0, math.random(225, 250), 0, math.random(150, 450))
				}):Play()
			end
		end)

		task.delay(math.random(300, 600) / 6000, function()
			if oldSound and oldSound.Parent and oldActive then
				playSoundSafe(oldSound, 0.25 + math.random() / 10, math.random(55, 145) / 100, 1)
			end
		end)

		task.spawn(function()
			while oldImage and oldImage.Parent and oldActive do
				oldImage.Position = UDim2.new(
					math.random(50, 900) / 1000,
					0,
					math.random(50, 900) / 1000,
					0
				)
				oldImage.Rotation = math.random(-60, 30)
				wait(8)
			end
		end)
	end
end)

-- Chuyển sang jumpscare mới sau 2-3 giây
task.delay(math.random(1, 1.5), function()
	if not screenGui.Parent or transitioning then
		return
	end

	transitioning = true
	oldActive = false

	wait(0.1)

	-- tween jumpscare cũ về giữa màn hình trước khi tắt
	local oldBackTween = TweenService:Create(oldImage, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(0, 2500, 0, 2500),
		Rotation = math.random(0,60)
	})
	oldBackTween:Play()

	oldBackTween.Completed:Wait(1)

	local tweenv2 = TweenService:Create(oldImage, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		ImageTransparency = 1
	})
	tweenv2:Play()

	bg:Destroy()

	-- để jumpscare mới tồn tại thêm 1 giây rồi xoá GUI
	task.wait(1)

	-- dừng âm thanh cũ để không chồng
	if oldSound then
		oldSound:Stop()
	end

	if screenGui and screenGui.Parent then
		screenGui:Destroy()
	end
	end)
