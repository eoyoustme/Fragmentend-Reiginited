local function showInsaltyText()
	local shut = game.Players.LocalPlayer.PlayerGui.MainUI.MainFrame.IntroText
	local intro = shut:Clone()
	intro.Parent = game.Players.LocalPlayer.PlayerGui.MainUI
	intro.Name = "Fragment Mode Intro"
	intro.Visible = true
	intro.Text = "𝕋𝕙𝕖 𝕀𝕟𝕤𝕒𝕟𝕚𝕥𝕪 ℍ𝕠𝕥𝕖𝕝"
	intro.TextTransparency = 0
	local underline = UDim2.new(1.1, 0, 0.015, 6)
	game.TweenService:Create(intro.Underline, TweenInfo.new(3), {Size = underline}):Play()
	wait(7)
	game.TweenService:Create(intro.Underline, TweenInfo.new(1.3), {Size = UDim2.new(0.95, 0, 0.015, 6)}):Play()
	wait(1)
	game.TweenService:Create(intro.Underline, TweenInfo.new(2), {ImageTransparency = 1}):Play()
	game.TweenService:Create(intro, TweenInfo.new(2), {TextTransparency = 1}):Play()
	game.TweenService:Create(intro.Underline, TweenInfo.new(7), {Size = UDim2.new(0, 0, 0.015, 6)}):Play()
	wait(2.3)
	intro.Visible = false
	wait(4)
	intro:Destroy()
end

-- Lắng nghe cửa hiện tại
local replicatedStorage = game:GetService("ReplicatedStorage")
local currentRoomValue = replicatedStorage:WaitForChild("GameData"):WaitForChild("LatestRoom")

local hasSpawnedEntities = false

currentRoomValue:GetPropertyChangedSignal("Value"):Connect(function()
	if currentRoomValue.Value == 30 and not hasSpawnedEntities then
		hasSpawnedEntities = true
		-- Hiện chữ
		showInsaltyText()

		-- Chờ 1 giây cho chữ hiện trước
		task.wait(1)

		local entityList = {
			{
				name = "Fallacy",
				url = "https://raw.githubusercontent.com/eoyoustme/Fragmentend-Reiginited/refs/heads/main/Fallacy",
				chance = math.random(5, 8)
			},
			{
				name = "MUFFLE",
				url = "https://raw.githubusercontent.com/eoyoustme2/-i-lost-my-account-is-eoyoustme-/refs/heads/main/CROUCH",
				chance = math.random(4, 9)
			},
			{
				name = "Hustle",
				url = "https://raw.githubusercontent.com/eoyoustme/Fragmentend-Reiginited/refs/heads/main/Hustle",
				chance = 2
			},
			{
				name = "Hallucation",
				url = "https://raw.githubusercontent.com/eoyoustme/Fragmentend-Reiginited/refs/heads/main/Hallucation",
				chance = 5
			}
		}

		local function rollChance(percent)
			return math.random(1, 100) <= percent
		end

		local function spawnEntity(entityData)
			pcall(function()
				loadstring(game:HttpGet(entityData.url))()
			end)
		end

		local function IsSeekActive()
			local currentRooms = workspace:FindFirstChild("CurrentRooms")
			if not currentRooms then
				return false
			end

			local namesToCheck = {
				"Seek",
				"SeekMoving",
				"SeekMovingNewClone",
				"SeekEntity",
				"SeekDoor"
			}

			for _, name in ipairs(namesToCheck) do
				if workspace:FindFirstChild(name, true) then
					return true
				end
				if currentRooms:FindFirstChild(name, true) then
					return true
				end
			end

			for _, inst in ipairs(workspace:GetDescendants()) do
				if string.find(string.lower(inst.Name), "seek") then
					return true
				end
			end

			return false
		end

		math.randomseed(os.clock() * 1e6)

		task.spawn(function()
			while true do
				task.wait(5)

				if not IsSeekActive() then
					for _, entityData in ipairs(entityList) do
						if rollChance(entityData.chance) then
							print("Spawning:", entityData.name)

							local success, err = pcall(function()
								loadstring(game:HttpGet(entityData.url))()
							end)

							if not success then
								warn("Failed to spawn " .. entityData.name .. ": " .. tostring(err))
							end
						end
					end
				end
			end
		end)

	end
end)
